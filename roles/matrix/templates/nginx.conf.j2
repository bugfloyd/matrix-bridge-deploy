# Redirect HTTP to HTTPS
server {
    listen 80;
    server_name {{ matrix_hostname }} {{ element_hostname }};

    location / {
        return 301 https://$host$request_uri;
    }
}

# Matrix Synapse — client API + well-known
server {
    listen 443 ssl;
    http2 on;
    server_name {{ matrix_hostname }};

    ssl_certificate {{ matrix_tls_cert_path }};
    ssl_certificate_key {{ matrix_tls_key_path }};
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384;
    ssl_prefer_server_ciphers off;

    client_max_body_size 50M;

    # Federation delegation
    location /.well-known/matrix/server {
        default_type application/json;
        return 200 '{"m.server": "{{ matrix_hostname }}:{{ matrix_federation_port | default(8448) }}"}';
    }

    location /.well-known/matrix/client {
        default_type application/json;
        add_header Access-Control-Allow-Origin *;
        return 200 '{"m.homeserver": {"base_url": "https://{{ matrix_hostname }}"}}';
    }

    # Synapse client + admin API
    location /_matrix {
        proxy_pass http://synapse:8008;
        proxy_set_header X-Forwarded-For $remote_addr;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Host $host;
        proxy_read_timeout 600s;
        proxy_send_timeout 600s;
    }

    location /_synapse {
        proxy_pass http://synapse:8008;
        proxy_set_header X-Forwarded-For $remote_addr;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Host $host;
    }
}

# Matrix Federation — server-to-server
server {
    listen {{ matrix_federation_port | default(8448) }} ssl;
    http2 on;
    server_name {{ matrix_hostname }};

    ssl_certificate {{ matrix_tls_cert_path }};
    ssl_certificate_key {{ matrix_tls_key_path }};
    ssl_protocols TLSv1.2 TLSv1.3;

    client_max_body_size 50M;

    location / {
        proxy_pass http://synapse:8008;
        proxy_set_header X-Forwarded-For $remote_addr;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Host $host;
    }
}

{% for peer in federation_peers | default([]) %}
# Serve correct .well-known for federated peer {{ peer.hostname }}
# When Synapse resolves {{ peer.hostname }} to localhost (via /etc/hosts + DNAT),
# it hits this Nginx on port 443. This block returns the correct federation port.
server {
    listen 443 ssl;
    http2 on;
    server_name {{ peer.hostname }};

    ssl_certificate {{ matrix_tls_cert_path }};
    ssl_certificate_key {{ matrix_tls_key_path }};

    location /.well-known/matrix/server {
        default_type application/json;
        return 200 '{"m.server": "{{ peer.hostname }}:{{ peer.port }}"}';
    }

    location / {
        return 404;
    }
}

{% endfor %}
# Element Web client
server {
    listen 443 ssl;
    http2 on;
    server_name {{ element_hostname }};

    ssl_certificate {{ matrix_tls_cert_path }};
    ssl_certificate_key {{ matrix_tls_key_path }};
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384;
    ssl_prefer_server_ciphers off;

    location / {
        proxy_pass http://element:80;
        proxy_set_header Host $host;
    }
}
